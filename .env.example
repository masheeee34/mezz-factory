# ── Email (confirmation de commande) ──────────────────────────────
# Copie ce fichier en ".env.local" et remplis les valeurs.
# Exemple avec Gmail (le plus simple pour démarrer) :
#
#   1. Active la validation en 2 étapes sur le compte Gmail.
#   2. Crée un "mot de passe d'application" :
#      https://myaccount.google.com/apppasswords
#   3. Colle-le dans SMTP_PASS ci-dessous (16 caractères, sans espaces).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=Mezzshop951@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx

# Email qui reçoit les notifications de commande (par défaut = SMTP_USER)
SHOP_EMAIL=Mezzshop951@gmail.com

# URL publique du site (pour afficher le logo dans les emails).
# En local laisse localhost ; en prod mets ton vrai domaine.
SITE_URL=http://localhost:3005
